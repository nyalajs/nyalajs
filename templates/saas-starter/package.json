{
    "name": "nyala-saas-starter",
    "version": "1.0.0",
    "description": "Production-ready SaaS starter with Nyala Framework",
    "private": true,
    "scripts": {
        "dev": "tsx watch bootstrap/main.ts",
        "build": "tsc",
        "start": "node dist/bootstrap/main.js",
        "test": "vitest run --passWithNoTests",
        "test:unit": "vitest run tests/unit",
        "test:integration": "vitest run tests/integration",
        "test:e2e": "vitest run tests/e2e",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "db:migrate": "tsx database/migrate.ts",
        "db:rollback": "tsx database/rollback.ts",
        "db:fresh": "tsx database/fresh.ts",
        "db:seed": "tsx database/seed.ts",
        "lint": "eslint app bootstrap --ext .ts",
        "lint:fix": "eslint app bootstrap --ext .ts --fix",
        "format": "prettier --write \"{app,bootstrap,config,database,routes}/**/*.ts\"",
        "format:check": "prettier --check \"{app,bootstrap,config,database,routes}/**/*.ts\"",
        "docker:build": "docker build -t nyala-saas .",
        "docker:up": "docker-compose up -d",
        "docker:down": "docker-compose down"
    },
    "dependencies": {
        "@nyalajs/core": "*",
        "@nyalajs/http": "*",
        "@nyalajs/security": "*",
        "@nyalajs/tenancy": "*",
        "@nyalajs/audit": "*",
        "@nyalajs/observability": "*",
        "@nyalajs/config": "*",
        "@nyalajs/database": "*",
        "@nyalajs/validation": "*",
        "@nyalajs/events": "*",
        "@nyalajs/queue": "*",
        "@nyalajs/mail": "*",
        "@nyalajs/notifications": "*",
        "@nyalajs/storage": "*",
        "@nyalajs/scheduler": "*",
        "@nyalajs/cache": "*",
        "reflect-metadata": "^0.2.1",
        "drizzle-orm": "^0.29.0",
        "postgres": "^3.4.3",
        "zod": "^3.22.4",
        "bcrypt": "^5.1.1",
        "jsonwebtoken": "^9.0.2",
        "dotenv": "^16.4.1"
    },
    "devDependencies": {
        "typescript": "^5.3.3",
        "tsx": "^4.7.0",
        "ts-node": "^10.9.2",
        "@types/node": "^20.10.6",
        "@types/bcrypt": "^5.0.2",
        "@types/jsonwebtoken": "^9.0.5",
        "vitest": "^1.0.4",
        "@vitest/coverage-v8": "^1.0.4",
        "eslint": "^8.56.0",
        "@typescript-eslint/eslint-plugin": "^6.17.0",
        "@typescript-eslint/parser": "^6.17.0",
        "prettier": "^3.1.1",
        "drizzle-kit": "^0.20.9",
        "husky": "^8.0.3",
        "lint-staged": "^15.2.0"
    },
    "lint-staged": {
        "*.ts": [
            "eslint --fix",
            "prettier --write"
        ]
    }
}